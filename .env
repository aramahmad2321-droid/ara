# ====================================
# ZANA AI — Environment Configuration
# ====================================

# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000

# MongoDB (local default — change if using Atlas)
MONGODB_URI=mongodb://localhost:27017/zana-ai

# JWT Secrets (CHANGE THESE IN PRODUCTION)
JWT_SECRET=zana-ai-jwt-secret-please-change-in-production-2025
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=zana-ai-refresh-secret-please-change-in-production-2025
JWT_REFRESH_EXPIRES_IN=30d

# AI Provider — OpenRouter (free models)
AI_PROVIDER=openai
OPENAI_API_KEY=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
OPENAI_MODEL=openrouter/auto
AI_BASE_URL=https://openrouter.ai/api/v1

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — Nodemailer (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Zana AI <noreply@zana-ai.com>"

# Session / Cookie
SESSION_SECRET=zana-ai-session-secret-change-this-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AI_RATE_LIMIT_MAX=50

# Admin — first user with this email gets admin role
ADMIN_EMAIL=admin@zana-ai.com
